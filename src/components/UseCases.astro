---
/**
 * Two-column use-case section — Marketers vs Individuals.
 * Demonstrates platform value for different user segments.
 */
const t = (Astro.locals as any).t || {};
const ucT = t.useCases || {};

const marketers = [
  { title: ucT.marketer1Title || 'Track Competitors', desc: ucT.marketer1Desc || 'Monitor competitor posting patterns, engagement rates, and content strategies.' },
  { title: ucT.marketer2Title || 'Monitor Engagement Spikes', desc: ucT.marketer2Desc || 'Get alerts when accounts experience unusual growth or viral content.' },
  { title: ucT.marketer3Title || 'Influencer Discovery', desc: ucT.marketer3Desc || 'Find and vet influencers based on real engagement data and audience quality.' },
];

const individuals = [
  { title: ucT.individual1Title || 'Browse Without an Account', desc: ucT.individual1Desc || 'View stories and posts without needing to log in or create an account.' },
  { title: ucT.individual2Title || 'Track Engagement Patterns', desc: ucT.individual2Desc || 'See how audiences interact with specific accounts and content.' },
  { title: ucT.individual3Title || 'Content Performance Insights', desc: ucT.individual3Desc || 'Understand engagement patterns and content performance across profiles.' },
];
---

<section id="use-cases" class="cv-auto py-20 lg:py-28 bg-dark-800/30">
  <div class="section-container">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">
        {ucT.heading || 'Built for'} <span class="gradient-text">{ucT.headingHighlight || 'Every Use Case'}</span>
      </h2>
      <p class="text-dark-400 text-lg max-w-2xl mx-auto">
        {ucT.subtitle || "Whether you're a marketer or an individual, IGStoryPeek delivers the insights you need."}
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 lg:gap-12">
      <!-- Marketers -->
      <div class="glass p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white">{ucT.forMarketers || 'For Marketers'}</h3>
        </div>
        <ul class="space-y-5">
          {marketers.map((item) => (
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <h4 class="text-sm font-semibold text-white">{item.title}</h4>
                <p class="text-sm text-dark-400 mt-0.5">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <!-- Individuals -->
      <div class="glass p-8">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 rounded-xl bg-secondary/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white">{ucT.forIndividuals || 'For Individuals'}</h3>
        </div>
        <ul class="space-y-5">
          {individuals.map((item) => (
            <li class="flex gap-3">
              <svg class="w-5 h-5 text-secondary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              <div>
                <h4 class="text-sm font-semibold text-white">{item.title}</h4>
                <p class="text-sm text-dark-400 mt-0.5">{item.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

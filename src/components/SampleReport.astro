---
/**
 * Static sample analytics report — demonstrates what the tool produces.
 * Uses pre-rendered data for @instagram (a popular public account).
 */
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};

const sample = {
  username: 'instagram',
  displayName: 'Instagram',
  followers: '676M',
  following: '382',
  posts: '7,842',
  engagementRate: '0.42%',
  avgLikes: '2.8M',
  avgComments: '18.2K',
  topFormat: 'Reels',
  postingFrequency: '1.4 posts/day',
};
---

<section class="py-20 lg:py-28 bg-dark-800/30">
  <div class="section-container max-w-5xl">
    <div class="text-center mb-10">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">
        See a <span class="gradient-text">Live Example</span>
      </h2>
      <p class="text-dark-400 text-lg max-w-2xl mx-auto">
        Here's what a real analytics report looks like for a public Instagram account.
      </p>
    </div>

    <div class="glass p-6 lg:p-8">
      <!-- Profile header -->
      <div class="flex flex-col sm:flex-row items-center gap-4 sm:gap-6 mb-8 pb-6 border-b border-white/10">
        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-pink-500 via-red-500 to-yellow-500 flex items-center justify-center text-white font-bold text-xl">IG</div>
        <div class="text-center sm:text-left">
          <h3 class="text-xl font-heading font-bold text-white">@{sample.username}</h3>
          <p class="text-sm text-dark-400">{sample.displayName} — Official Account</p>
        </div>
        <div class="sm:ml-auto flex gap-6 text-center">
          <div>
            <p class="text-lg font-bold text-white">{sample.followers}</p>
            <p class="text-xs text-dark-500">Followers</p>
          </div>
          <div>
            <p class="text-lg font-bold text-white">{sample.following}</p>
            <p class="text-xs text-dark-500">Following</p>
          </div>
          <div>
            <p class="text-lg font-bold text-white">{sample.posts}</p>
            <p class="text-xs text-dark-500">Posts</p>
          </div>
        </div>
      </div>

      <!-- Metrics grid -->
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-dark-800/50 rounded-lg p-4">
          <p class="text-xs text-dark-500 mb-1">Engagement Rate</p>
          <p class="text-2xl font-bold text-primary">{sample.engagementRate}</p>
        </div>
        <div class="bg-dark-800/50 rounded-lg p-4">
          <p class="text-xs text-dark-500 mb-1">Avg. Likes</p>
          <p class="text-2xl font-bold text-white">{sample.avgLikes}</p>
        </div>
        <div class="bg-dark-800/50 rounded-lg p-4">
          <p class="text-xs text-dark-500 mb-1">Avg. Comments</p>
          <p class="text-2xl font-bold text-white">{sample.avgComments}</p>
        </div>
        <div class="bg-dark-800/50 rounded-lg p-4">
          <p class="text-xs text-dark-500 mb-1">Top Format</p>
          <p class="text-2xl font-bold text-white">{sample.topFormat}</p>
        </div>
      </div>

      <!-- Activity heatmap preview -->
      <div class="bg-dark-800/50 rounded-lg p-4 mb-6">
        <p class="text-sm font-semibold text-white mb-3">Posting Activity (Last 30 Days)</p>
        <div class="grid grid-cols-7 gap-1">
          {[3,1,2,4,2,1,0, 2,3,1,2,3,2,1, 1,2,4,3,1,2,0, 3,1,2,2,4,1,1, 2,3].map((v) => (
            <div
              class="aspect-square rounded-sm"
              style={`background: ${v === 0 ? 'rgba(225,48,108,0.05)' : v === 1 ? 'rgba(225,48,108,0.2)' : v === 2 ? 'rgba(225,48,108,0.4)' : v === 3 ? 'rgba(225,48,108,0.6)' : 'rgba(225,48,108,0.85)'}`}
            />
          ))}
        </div>
        <div class="flex items-center gap-2 mt-2 text-xs text-dark-500">
          <span>Less</span>
          <div class="flex gap-0.5">
            {[0.05, 0.2, 0.4, 0.6, 0.85].map((o) => (
              <div class="w-3 h-3 rounded-sm" style={`background: rgba(225,48,108,${o})`} />
            ))}
          </div>
          <span>More</span>
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <a href={getLocalizedPath('/search/instagram', lang)} class="btn-primary text-sm px-6 py-2.5 inline-flex items-center gap-2">
          View Full Report
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
        </a>
        <p class="text-xs text-dark-500 mt-3">Search any public username to generate your own report — free, no login required.</p>
      </div>
    </div>
  </div>
</section>

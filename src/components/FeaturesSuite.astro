---
/**
 * Product suite section — showcases the four main product categories.
 * Each card links to a feature page.
 */
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};
const fsT = t.featuresSuite || {};

const products = [
  {
    title: fsT.analyzer?.title || 'Instagram Analyzer',
    description: fsT.analyzer?.description || 'Deep-dive analytics for any public profile. Engagement rates, growth trends, content performance, and audience insights.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />`,
    color: 'primary',
    href: getLocalizedPath('/', lang) + '#hero',
  },
  {
    title: fsT.browser?.title || 'Content Browser',
    description: fsT.browser?.description || 'Browse stories, posts, and highlights without logging in — no account needed.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />`,
    color: 'secondary',
    href: getLocalizedPath('/', lang) + '#hero',
  },
  {
    title: fsT.downloader?.title || 'Downloader',
    description: fsT.downloader?.description || 'Save stories, reels, and posts in original quality. Keep a record for competitive analysis or personal use.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />`,
    color: 'primary',
    href: getLocalizedPath('/', lang) + '#hero',
  },
  {
    title: fsT.tracker?.title || 'Activity Tracker',
    description: fsT.tracker?.description || 'Set up automated alerts for any public account. Get notified about new posts, story updates, and follower changes.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />`,
    color: 'secondary',
    href: getLocalizedPath('/', lang) + '#hero',
  },
];
---

<section class="cv-auto py-20 lg:py-28">
  <div class="section-container">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">
        {fsT.heading || 'Complete'} <span class="gradient-text">{fsT.headingHighlight || 'Product Suite'}</span>
      </h2>
      <p class="text-dark-400 text-lg max-w-2xl mx-auto">
        {fsT.subtitle || 'Powerful tools designed to give you a complete picture of any public Instagram presence.'}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {products.map((p) => (
        <a href={p.href} class="glass p-8 card-hover group block">
          <div class={`w-12 h-12 rounded-xl ${p.color === 'primary' ? 'bg-primary/10' : 'bg-secondary/10'} flex items-center justify-center mb-5 group-hover:scale-110 transition-transform`}>
            <svg class={`w-6 h-6 ${p.color === 'primary' ? 'text-primary' : 'text-secondary'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <Fragment set:html={p.icon} />
            </svg>
          </div>
          <h3 class="text-xl font-heading font-semibold text-white mb-2 group-hover:text-primary transition-colors">{p.title}</h3>
          <p class="text-sm text-dark-400 leading-relaxed">{p.description}</p>
          <div class="mt-4 flex items-center gap-1 text-sm text-primary opacity-0 group-hover:opacity-100 transition-opacity">
            {fsT.learnMore || 'Learn more'}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

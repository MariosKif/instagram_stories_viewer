---
import { popularAccounts } from '../data/popularAccounts';
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};
---

<section class="py-16 lg:py-20 cv-auto">
  <div class="section-container">
    <h2 class="text-2xl sm:text-3xl font-heading font-bold text-white text-center mb-8">
      {t.popularAccounts?.heading || 'Popular Instagram Profiles'}
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3 sm:gap-4">
      {popularAccounts.map((account) => (
        <a
          href={getLocalizedPath(`/search/${account.username}`, lang)}
          class="glass p-3 sm:p-4 text-center card-hover block group"
        >
          <p class="text-sm font-semibold text-white group-hover:text-primary transition-colors truncate">
            @{account.username}
          </p>
          <span class="badge mt-2 text-[10px] scale-90">{t.popularAccounts?.categories?.[account.category] || account.category}</span>
        </a>
      ))}
    </div>
  </div>
</section>

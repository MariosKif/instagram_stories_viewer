---
/**
 * Hero section — the first thing visitors see.
 * Includes headline, subheadline, search bar, sample report CTA, and feature badges.
 * Glassmorphism + animated gradient background.
 */
import SearchBar from './SearchBar.astro';
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};
const heroT = t.hero || {};
---

<section id="hero" class="relative min-h-[90vh] flex items-center overflow-hidden">
  <!-- Animated background -->
  <div class="absolute inset-0 animated-gradient"></div>

  <!-- Subtle grid overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M60 0H0v60&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot;/%3E%3C/svg%3E');"></div>

  <!-- Floating orbs -->
  <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary/10 rounded-full blur-3xl animate-float" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 right-1/4 w-72 h-72 bg-secondary/10 rounded-full blur-3xl animate-float" style="animation-delay: -3s;" aria-hidden="true"></div>

  <div class="relative section-container py-24 lg:py-32">
    <div class="max-w-4xl mx-auto text-center">
      <!-- Headline -->
      <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-heading font-bold leading-tight mb-6 animate-fade-in">
        {heroT.title || 'Your All-in-One'}
        <span class="gradient-text"> {heroT.titleHighlight || 'Social Media Analytics'}</span> {heroT.titleEnd || 'Tool'}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg sm:text-xl text-dark-300 max-w-2xl mx-auto mb-10 animate-slide-up">
        {heroT.subtitle || 'Analyze public profiles, track engagement trends, and explore content — across platforms, no account needed.'}
      </p>

      <!-- Search bar -->
      <div class="max-w-2xl mx-auto mb-6 animate-slide-up" style="animation-delay: 0.15s;">
        <SearchBar size="large" />
      </div>

      <!-- Secondary CTA -->
      <div class="mb-10 animate-slide-up" style="animation-delay: 0.25s;">
        <a href={getLocalizedPath('/search/instagram', lang)} class="btn-ghost text-primary hover:text-primary-300 text-sm underline underline-offset-4 decoration-primary/30 hover:decoration-primary/60">
          {heroT.viewSample || 'View Sample Report'}
        </a>
      </div>

      <!-- Feature badges -->
      <div class="flex flex-wrap justify-center gap-3 animate-slide-up" style="animation-delay: 0.35s;">
        <span class="badge">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          {heroT.badge1 || 'AI Powered'}
        </span>
        <span class="badge">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
          {heroT.badge2 || 'No Account Needed'}
        </span>
        <span class="badge">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" /></svg>
          {heroT.badge3 || 'Public Data Only'}
        </span>
        <span class="badge">
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          {heroT.badge4 || 'Real-Time Analysis'}
        </span>
      </div>
    </div>
  </div>
</section>

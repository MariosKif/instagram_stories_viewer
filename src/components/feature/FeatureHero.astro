---
import SearchBar from '../SearchBar.astro';
import PlatformBreadcrumb from './PlatformBreadcrumb.astro';
import type { Platform, Category, Feature } from '../../data/features';

interface Props {
  platform: Platform;
  category: Category;
  feature: Feature;
}

const { platform, category, feature } = Astro.props;

const badgeIcons = [
  `<path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>`,
  `<path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/>`,
];
---

<section class="relative min-h-[70vh] flex items-center overflow-hidden">
  <div class="absolute inset-0 animated-gradient"></div>
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cpath d=&quot;M60 0H0v60&quot; fill=&quot;none&quot; stroke=&quot;%23fff&quot; stroke-width=&quot;0.5&quot;/%3E%3C/svg%3E');"></div>
  <div class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full blur-3xl animate-float" style={`background: ${platform.color}10`}></div>
  <div class="absolute bottom-1/4 right-1/4 w-72 h-72 rounded-full blur-3xl animate-float" style={`background: ${platform.color}08; animation-delay: -3s;`}></div>

  <div class="relative section-container py-24 lg:py-32">
    <div class="max-w-4xl mx-auto">
      <div class="mb-8 animate-fade-in">
        <PlatformBreadcrumb
          platformId={platform.id}
          platformLabel={platform.label}
          platformColor={platform.color}
          categoryTitle={category.title}
          featureLabel={feature.label}
        />
      </div>

      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full border mb-6 animate-fade-in" style={`background: ${platform.color}10; border-color: ${platform.color}30`}>
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" style={`color: ${platform.color}`}>
            <Fragment set:html={platform.brandIcon} />
          </svg>
          <span class="text-sm font-medium" style={`color: ${platform.color}`}>{platform.label} {category.title}</span>
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-heading font-bold leading-tight mb-6 animate-fade-in">
          <span style={`color: ${platform.color}`}>{platform.label}</span>
          <span class="text-white"> {feature.label}</span>
        </h1>

        <p class="text-lg sm:text-xl text-dark-300 max-w-2xl mx-auto mb-10 animate-slide-up">
          {feature.description}
        </p>

        <div class="max-w-2xl mx-auto mb-6 animate-slide-up" style="animation-delay: 0.15s;">
          <SearchBar size="large" />
        </div>

        <!-- Dynamic badges from feature data -->
        <div class="flex flex-wrap justify-center gap-3 animate-slide-up" style="animation-delay: 0.25s;">
          {feature.badges.map((badgeText, i) => (
            <span class="badge" style={`background: ${platform.color}10; color: ${platform.color}; border-color: ${platform.color}20`}>
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <Fragment set:html={badgeIcons[i % badgeIcons.length]} />
              </svg>
              {badgeText}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

---
import type { Step } from '../../data/features';

interface Props {
  steps: Step[];
  platformColor: string;
  heading: string;
  subheading: string;
}

const { steps, platformColor, heading, subheading } = Astro.props;
---

<section class="py-20 lg:py-28">
  <div class="section-container">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4 text-white" set:html={heading} />
      <p class="text-dark-400 text-lg max-w-2xl mx-auto">
        {subheading}
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {steps.map((step, i) => (
        <div class="glass p-6 card-hover group relative">
          <div class="w-10 h-10 rounded-full flex items-center justify-center mb-4 text-lg font-heading font-bold" style={`background: ${platformColor}15; color: ${platformColor}`}>
            {i + 1}
          </div>
          <h3 class="text-lg font-semibold text-white mb-2">{step.title}</h3>
          <p class="text-sm text-dark-400 leading-relaxed">{step.description}</p>
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-10 -right-3 w-6 h-px" style={`background: ${platformColor}30`}></div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

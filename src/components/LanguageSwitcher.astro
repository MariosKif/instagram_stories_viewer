---
import { languages, allLanguages, type Language, getLocalizedPath } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const currentPath = Astro.url.pathname;

// Strip lang prefix to get base path
const langRegex = new RegExp(`^/(${allLanguages.join('|')})(\/|$)`);
const basePath = currentPath.replace(langRegex, '/').replace(/^\/$/, '/') || '/';
---

<!-- Trigger button -->
<button
  class="js-lang-trigger flex items-center gap-1.5 px-2.5 py-1.5 rounded-lg text-sm text-dark-300 hover:text-white hover:bg-white/5 transition-colors"
  aria-label="Select language"
>
  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
    <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
  </svg>
  <span class="uppercase font-medium text-xs">{lang}</span>
  <svg class="w-3 h-3 transition-transform duration-200 js-lang-chevron" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
  </svg>
</button>

<!-- Overlay template (will be moved to body by JS) -->
<template class="js-lang-template">
  <div class="js-lang-overlay hidden fixed inset-0 z-[9999]">
    <div class="js-lang-backdrop absolute inset-0 bg-black/50"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[92vw] max-w-[540px] bg-dark-900 border border-white/10 rounded-2xl shadow-2xl shadow-black/60 p-4 max-h-[80vh] overflow-y-auto">
      <div class="flex items-center justify-between mb-3 pb-3 border-b border-white/10">
        <div class="flex items-center gap-2 text-white">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064" />
          </svg>
          <span class="text-sm font-semibold">Select Language</span>
        </div>
        <button class="js-lang-close p-1 text-dark-400 hover:text-white transition-colors rounded-lg hover:bg-white/5" aria-label="Close">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-0.5">
        {allLanguages.map((l) => (
          <a
            href={getLocalizedPath(basePath, l)}
            class={`flex items-center gap-1.5 px-2.5 py-2 rounded-lg text-[13px] transition-colors ${
              l === lang
                ? 'bg-primary/10 text-primary font-medium'
                : 'text-dark-300 hover:text-white hover:bg-white/5'
            }`}
            data-lang={l}
          >
            {l === lang && (
              <svg class="w-3 h-3 text-primary shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
            )}
            <span class={l !== lang ? 'ml-[18px]' : ''}>{languages[l].name}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</template>

<script is:inline>
  (function() {
    // Only initialize once
    if (window.__langSwitcherInit) return;
    window.__langSwitcherInit = true;

    // Grab the first template and inject its content into document.body
    var tpl = document.querySelector('.js-lang-template');
    if (!tpl) return;
    var overlay = tpl.content.firstElementChild.cloneNode(true);
    document.body.appendChild(overlay);

    // Remove all templates (avoid duplicates from multiple component instances)
    document.querySelectorAll('.js-lang-template').forEach(function(t) { t.remove(); });

    var backdrop = overlay.querySelector('.js-lang-backdrop');
    var closeBtn = overlay.querySelector('.js-lang-close');

    function show() {
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function hide() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
      document.querySelectorAll('.js-lang-chevron').forEach(function(c) {
        c.classList.remove('rotate-180');
      });
    }

    // Bind ALL trigger buttons (desktop + mobile)
    document.querySelectorAll('.js-lang-trigger').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        show();
        btn.querySelector('.js-lang-chevron').classList.add('rotate-180');
      });
    });

    backdrop.addEventListener('click', hide);
    closeBtn.addEventListener('click', hide);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !overlay.classList.contains('hidden')) hide();
    });

    // Set cookie on language link click
    overlay.querySelectorAll('a[data-lang]').forEach(function(link) {
      link.addEventListener('click', function() {
        var lang = this.getAttribute('data-lang');
        var d = new Date();
        d.setFullYear(d.getFullYear() + 1);
        var sec = location.protocol === 'https:' ? '; Secure' : '';
        document.cookie = 'preferred-language=' + lang + '; path=/; expires=' + d.toUTCString() + '; SameSite=Lax' + sec;
      });
    });
  })();
</script>

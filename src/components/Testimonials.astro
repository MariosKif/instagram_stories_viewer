---
/**
 * Feature highlights — honest use-case cards replacing fake testimonials.
 */
const t = (Astro.locals as any).t || {};
const tT = t.testimonials || {};

const highlights = [
  {
    icon: 'search',
    title: 'Cross-Platform Analytics',
    text: 'Analyze public Instagram profiles from a single dashboard. View stories, posts, reels, and highlights while comparing engagement rates and content performance.',
  },
  {
    icon: 'chart',
    title: 'Real-Time Monitoring',
    text: 'Track posting patterns, follower changes, and engagement spikes as they happen. Set up alerts for accounts you follow to never miss important activity.',
  },
  {
    icon: 'download',
    title: 'Content Tools',
    text: 'View and save stories, reels, posts, and highlights from public accounts. Download content in original quality for offline research and reference.',
  },
  {
    icon: 'shield',
    title: 'Privacy First',
    text: 'No login required on any social platform. We only access publicly available data and never store your search history or personal information.',
  },
];
---

<section class="cv-auto py-20 lg:py-28 bg-dark-800/30">
  <div class="section-container">
    <div class="text-center mb-14">
      <h2 class="text-3xl sm:text-4xl font-heading font-bold mb-4">
        {tT.heading || 'Why Users Choose'} <span class="gradient-text">{tT.headingHighlight || 'IGStoryPeek'}</span>
      </h2>
      <p class="text-dark-400 text-lg max-w-2xl mx-auto">
        {tT.subtitle || 'Built for marketers, researchers, and anyone who wants to explore public social media data.'}
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {highlights.map((h) => (
        <div class="glass p-6 flex flex-col card-hover">
          <div class="w-10 h-10 rounded-lg bg-primary/10 flex items-center justify-center mb-4">
            {h.icon === 'search' && <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>}
            {h.icon === 'chart' && <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>}
            {h.icon === 'download' && <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>}
            {h.icon === 'shield' && <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>}
          </div>
          <h3 class="text-white font-semibold mb-2">{h.title}</h3>
          <p class="text-sm text-dark-300 leading-relaxed flex-1">{h.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

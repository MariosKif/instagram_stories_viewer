---
/**
 * Trust / social-proof bar — user count, security badges, compliance note.
 */
const t = (Astro.locals as any).t || {};
const trT = t.trust || {};
---

<section class="py-12 border-y border-white/5">
  <div class="section-container">
    <div class="flex flex-col md:flex-row items-center justify-center gap-8 lg:gap-16">
      <!-- User count -->
      <div class="flex items-center gap-3">
        <div class="flex -space-x-2">
          {['EM','SK','JR','ML','DP'].map((initials, i) => (
            <div
              class="w-8 h-8 rounded-full border-2 border-dark-900 flex items-center justify-center text-[10px] font-bold text-white"
              style={`background: linear-gradient(135deg, hsl(${190 + i * 25}, 80%, 50%), hsl(${210 + i * 25}, 80%, 40%))`}
            >
              {initials}
            </div>
          ))}
        </div>
        <div>
          <p class="text-sm font-semibold text-white">{trT.userCount || '50,000+ users'}</p>
          <p class="text-xs text-dark-500">{trT.trustLine || 'trust IGStoryPeek'}</p>
        </div>
      </div>

      <div class="hidden md:block w-px h-10 bg-white/10"></div>

      <!-- Security badges -->
      <div class="flex items-center gap-6">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span class="text-xs text-dark-400">{trT.sslEncrypted || 'SSL Encrypted'}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <span class="text-xs text-dark-400">{trT.gdprCompliant || 'GDPR Compliant'}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945" />
          </svg>
          <span class="text-xs text-dark-400">{trT.publicDataOnly || 'Public Data Only'}</span>
        </div>
      </div>

      <div class="hidden md:block w-px h-10 bg-white/10"></div>

      <!-- Compliance note -->
      <p class="text-xs text-dark-500 max-w-xs text-center md:text-left">
        {trT.complianceNote || 'All data is sourced from publicly available profiles in compliance with applicable laws.'}
      </p>
    </div>
  </div>
</section>

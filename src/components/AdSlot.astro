---
/**
 * Reusable Google AdSense ad slot component.
 * Drop into any page with: <AdSlot slot="1234567890" format="auto" responsive />
 */
interface Props {
  slot: string;
  format?: 'auto' | 'rectangle' | 'horizontal' | 'vertical';
  responsive?: boolean;
}

const { slot, format = 'auto', responsive = true } = Astro.props;
---

<div class="ad-slot my-6">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-1279144350888956"
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive={responsive ? 'true' : 'false'}
  ></ins>
  <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
</div>

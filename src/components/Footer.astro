---
/**
 * Site-wide footer with navigation, legal links, and branding.
 */
import { platforms } from '../data/features';
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};
const fT = t.footer || {};

const year = new Date().getFullYear();

// Top 3 features per platform for footer links
const platformLinks = platforms.map(p => ({
  id: p.id,
  label: p.label,
  color: p.color,
  features: p.categories.flatMap(c => c.features).slice(0, 3),
}));
---

<footer class="border-t border-white/5 bg-dark-950">
  <div class="section-container py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 mb-12">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href={getLocalizedPath('/', lang)} class="flex items-center gap-2 mb-4">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-primary to-secondary flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
            </svg>
          </div>
          <span class="text-lg font-heading font-bold text-white">IGStoryPeek</span>
        </a>
        <p class="text-sm text-dark-400 leading-relaxed">
          {fT.brandDescription || 'Social media analytics and content tools. Analyze public profiles, track engagement, and generate insights.'}
        </p>
      </div>

      <!-- Product -->
      <div>
        <p class="text-sm font-semibold text-white mb-4">{fT.product || 'Product'}</p>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/', lang) + '#features'} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.features || 'Features'}</a></li>
          <li><a href={getLocalizedPath('/pricing', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.pricing || 'Pricing'}</a></li>
          <li><a href={getLocalizedPath('/search/instagram', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.sampleReport || 'Sample Report'}</a></li>
          <li><a href={getLocalizedPath('/dashboard', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.dashboard || 'Dashboard'}</a></li>
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <p class="text-sm font-semibold text-white mb-4">{fT.resources || 'Resources'}</p>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/blog', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.blog || 'Blog'}</a></li>
          <li><a href={getLocalizedPath('/', lang) + '#use-cases'} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.useCases || 'Use Cases'}</a></li>
          <li><a href={getLocalizedPath('/', lang) + '#faq'} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.faqLink || 'FAQ'}</a></li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <p class="text-sm font-semibold text-white mb-4">{fT.legal || 'Legal'}</p>
        <ul class="space-y-2.5">
          <li><a href={getLocalizedPath('/privacy', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.privacyPolicy || 'Privacy Policy'}</a></li>
          <li><a href={getLocalizedPath('/terms', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.termsOfService || 'Terms of Service'}</a></li>
          <li><a href={getLocalizedPath('/about', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.aboutUs || 'About Us'}</a></li>
          <li><a href={getLocalizedPath('/contact', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.contact || 'Contact'}</a></li>
          <li><a href={getLocalizedPath('/cookie-policy', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.cookiePolicy || 'Cookie Policy'}</a></li>
          <li><a href={getLocalizedPath('/dmca', lang)} class="text-sm text-dark-400 hover:text-white transition-colors">{fT.dmca || 'DMCA'}</a></li>
        </ul>
      </div>
    </div>

    <!-- Platform links -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12 mb-12 pt-8 border-t border-white/5">
      {platformLinks.map(p => (
        <div>
          <p class="text-sm font-semibold mb-4" style={`color: ${p.color}`}>
            <a href={getLocalizedPath(`/${p.id}`, lang)} class="hover:underline">{p.label} {fT.tools || 'Tools'}</a>
          </p>
          <ul class="space-y-2.5">
            {p.features.map(f => (
              <li>
                <a href={getLocalizedPath(`/${p.id}/${f.slug}`, lang)} class="text-sm text-dark-400 hover:text-white transition-colors">
                  {f.label}
                </a>
              </li>
            ))}
            <li>
              <a href={getLocalizedPath(`/${p.id}`, lang)} class="text-sm hover:underline transition-colors" style={`color: ${p.color}`}>
                {fT.viewAll || 'View all'} &rarr;
              </a>
            </li>
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="pt-8 border-t border-white/5 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-dark-500">
        &copy; {year} {fT.copyright || 'IGStoryPeek. All rights reserved. Not affiliated with Instagram or Meta.'}
      </p>
      <p class="text-xs text-dark-500">
        {fT.dataSource || 'All data sourced from publicly available information.'}
      </p>
    </div>
  </div>
</footer>

---
import MainLayout from '../layouts/MainLayout.astro';
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
Astro.response.status = 404;
---

<MainLayout title="Page Not Found" noIndex={true}>
  <section class="flex items-center justify-center min-h-[60vh] px-4">
    <div class="text-center max-w-lg">
      <h1 class="text-7xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-indigo-500 to-purple-600 mb-4">404</h1>
      <p class="text-2xl font-semibold text-gray-800 mb-2">Page Not Found</p>
      <p class="text-gray-500 mb-8">The page you're looking for doesn't exist or has been moved.</p>

      <!-- Search bar -->
      <form action={getLocalizedPath('/search/', lang)} method="get" class="flex gap-2 max-w-sm mx-auto mb-8">
        <input
          type="text"
          name="q"
          placeholder="Search a username…"
          class="flex-1 px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"
        />
        <button type="submit" class="px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors">
          Search
        </button>
      </form>

      <!-- Quick links -->
      <div class="flex flex-wrap justify-center gap-4 text-sm">
        <a href={getLocalizedPath('/', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">Homepage</a>
        <a href={getLocalizedPath('/blog', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">Blog</a>
        <a href={getLocalizedPath('/instagram', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">Instagram</a>
        <a href={getLocalizedPath('/tiktok', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">TikTok</a>
        <a href={getLocalizedPath('/facebook', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">Facebook</a>
        <a href={getLocalizedPath('/snapchat', lang)} class="text-indigo-600 hover:text-indigo-800 underline underline-offset-2">Snapchat</a>
      </div>
    </div>
  </section>
</MainLayout>

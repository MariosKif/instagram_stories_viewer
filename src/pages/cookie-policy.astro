---
/**
 * Cookie Policy page — required for Google AdSense compliance.
 */
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import { getLocalizedPath } from '../i18n/utils';
import type { Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang || 'en';
const t = (Astro.locals as any).t || {};

const cookieFaqs = [
  {
    question: 'What personal information do analytics websites collect from visitors?',
    answer: 'Typical analytics data includes IP address, browser type, device information, pages visited, session duration, and referral source. IGStoryPeek collects this standard usage data to improve the service.',
  },
  {
    question: 'What is the difference between first-party and third-party cookies?',
    answer: 'First-party cookies are set by the website you are visiting (e.g., IGStoryPeek for authentication). Third-party cookies are set by external services embedded on the page, such as Google Analytics or Google AdSense.',
  },
  {
    question: 'Do I need to give consent before cookies are placed on my device?',
    answer: 'Under GDPR and similar regulations, websites must obtain consent before placing non-essential cookies. Essential cookies required for the site to function do not need separate consent.',
  },
  {
    question: 'How do I disable Google AdSense cookies?',
    answer: 'You can opt out of personalized advertising by visiting Google Ads Settings at adssettings.google.com. You can also use the NAI opt-out tool at networkadvertising.org or adjust cookie preferences in your browser settings.',
  },
];
---

<MainLayout title={t.legal?.cookiePolicyTitle || 'Cookie Policy'}>
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28">
    <div class="section-container max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-8">{t.legal?.cookiePolicyTitle || 'Cookie Policy'}</h1>
      <p class="text-sm text-dark-500 mb-10">{t.legal?.lastUpdated || 'Last updated'}: March 2026</p>

      <div class="space-y-8 text-dark-300 text-sm leading-relaxed">
        <div>
          <h2 class="text-lg font-semibold text-white mb-3">1. What Are Cookies</h2>
          <p>Cookies are small text files that are stored on your device when you visit a website. They help websites remember your preferences, understand how you use the site, and deliver relevant content and advertisements.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">2. How We Use Cookies</h2>
          <p>IGStoryPeek uses cookies for the following purposes:</p>

          <h3 class="text-sm font-semibold text-white mt-4 mb-2">Essential Cookies</h3>
          <p>These cookies are necessary for the website to function properly. They enable core features like user authentication, session management, and security. You cannot opt out of essential cookies.</p>
          <ul class="list-disc list-inside space-y-1 ml-2 mt-2">
            <li>Authentication tokens (Firebase Auth)</li>
            <li>Session identifiers</li>
            <li>Cookie consent preferences</li>
          </ul>

          <h3 class="text-sm font-semibold text-white mt-4 mb-2">Analytics Cookies</h3>
          <p>We use analytics cookies to understand how visitors interact with our website. This helps us improve our services and user experience.</p>
          <ul class="list-disc list-inside space-y-1 ml-2 mt-2">
            <li>Google Analytics — tracks page views, session duration, and user behavior</li>
          </ul>

          <h3 class="text-sm font-semibold text-white mt-4 mb-2">Advertising Cookies</h3>
          <p>We use advertising cookies to display relevant advertisements to our users. These cookies track your browsing activity to deliver personalized ads.</p>
          <ul class="list-disc list-inside space-y-1 ml-2 mt-2">
            <li>Google AdSense — serves personalized advertisements based on your interests</li>
            <li>Google uses the DoubleClick cookie to serve ads based on your visits to this and other sites</li>
          </ul>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">3. Google AdSense & Third-Party Advertising</h2>
          <p>We use Google AdSense to display advertisements on our website. Google AdSense uses cookies to serve ads based on your prior visits to our website and other websites on the Internet.</p>
          <p class="mt-2">Google's use of advertising cookies enables it and its partners to serve ads based on your visit to our site and/or other sites on the Internet. You may opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Google Ads Settings</a>.</p>
          <p class="mt-2">For more information about how Google uses data when you use our site, visit <a href="https://policies.google.com/technologies/partner-sites" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Google's Privacy & Terms</a>.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">4. Managing Cookies</h2>
          <p>You can control and manage cookies in several ways:</p>
          <ul class="list-disc list-inside space-y-1.5 ml-2 mt-2">
            <li><strong class="text-white">Browser settings:</strong> Most browsers allow you to refuse or accept cookies through their settings. Consult your browser's help documentation for instructions.</li>
            <li><strong class="text-white">Opt out of Google Ads:</strong> Visit <a href="https://adssettings.google.com" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">adssettings.google.com</a> to manage your Google ad preferences.</li>
            <li><strong class="text-white">NAI opt-out:</strong> Visit <a href="https://optout.networkadvertising.org" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">networkadvertising.org</a> to opt out of interest-based advertising.</li>
          </ul>
          <p class="mt-2">Please note that disabling cookies may affect the functionality of our website and your user experience.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">5. Your Rights (GDPR/CCPA)</h2>
          <p>Under the General Data Protection Regulation (GDPR) and the California Consumer Privacy Act (CCPA), you have the right to:</p>
          <ul class="list-disc list-inside space-y-1 ml-2 mt-2">
            <li>Know what personal data is collected via cookies</li>
            <li>Opt out of the sale of personal data (CCPA)</li>
            <li>Request deletion of personal data collected via cookies</li>
            <li>Withdraw consent for non-essential cookies at any time</li>
          </ul>
          <p class="mt-2">To exercise any of these rights, contact us at <a href="mailto:contact@igstorypeek.com" class="text-primary hover:underline">contact@igstorypeek.com</a>.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">6. Changes to This Policy</h2>
          <p>We may update this Cookie Policy from time to time. Changes will be posted on this page with an updated revision date.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">7. Contact Us</h2>
          <p>If you have questions about our use of cookies, contact us at <a href="mailto:contact@igstorypeek.com" class="text-primary hover:underline">contact@igstorypeek.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection faqs={cookieFaqs} />
</MainLayout>

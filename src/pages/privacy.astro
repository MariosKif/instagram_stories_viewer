---
/**
 * Privacy Policy page — legal compliance page.
 */
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import { getLocalizedPath } from '../i18n/utils';
import type { Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang || 'en';
const t = (Astro.locals as any).t || {};

const privacyFaqs = [
  {
    question: 'How does IGStoryPeek use my data?',
    answer: 'We use your data solely to provide and improve our service — this includes managing your account, storing search history for your convenience, enforcing usage limits, and communicating service updates.',
  },
  {
    question: 'Is IGStoryPeek GDPR compliant?',
    answer: 'Yes. We comply with the General Data Protection Regulation (GDPR) and the California Consumer Privacy Act (CCPA). You can request access to, correction of, or deletion of your personal data at any time.',
  },
  {
    question: 'Do you use cookies to track my browsing activity?',
    answer: 'We use essential cookies for authentication and session management. Analytics and advertising cookies (Google Analytics, Google AdSense) are also used but can be controlled through your browser settings or our Cookie Policy page.',
  },
  {
    question: 'Can IGStoryPeek access private accounts or messages?',
    answer: 'No. IGStoryPeek only accesses publicly available data. Private profiles, direct messages, and any content not publicly visible are never accessed by our tools.',
  },
  {
    question: 'How can I opt out of data collection?',
    answer: 'You can disable analytics and advertising cookies through your browser settings. To delete your account and all associated data, contact us at contact@igstorypeek.com.',
  },
];
---

<MainLayout title={t.legal?.privacyTitle || 'Privacy Policy'}>
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28">
    <div class="section-container max-w-3xl">
      <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white mb-8">{t.legal?.privacyTitle || 'Privacy Policy'}</h1>
      <p class="text-sm text-dark-500 mb-10">{t.legal?.lastUpdated || 'Last updated'}: March 2026</p>

      <div class="space-y-8 text-dark-300 text-sm leading-relaxed">
        <div>
          <h2 class="text-lg font-semibold text-white mb-3">1. Information We Collect</h2>
          <p>When you create an account, we collect your email address and basic authentication data. When you use our search features, we store your search queries and generated reports in association with your account.</p>
          <p class="mt-2">We also collect standard usage data including IP address, browser type, pages visited, and timestamps for analytics purposes.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">2. How We Use Your Information</h2>
          <ul class="list-disc list-inside space-y-1.5 ml-2">
            <li>To provide and maintain our service</li>
            <li>To manage your account and subscription</li>
            <li>To store your search history for your convenience</li>
            <li>To enforce usage limits and prevent abuse</li>
            <li>To improve our platform and user experience</li>
            <li>To communicate service updates and changes</li>
          </ul>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">3. Data Storage and Security</h2>
          <p>Your data is stored using Firebase (Google Cloud Platform) infrastructure with industry-standard encryption at rest and in transit. We implement appropriate security measures including SSL/TLS encryption, access controls, and regular security reviews.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">4. Instagram Data</h2>
          <p>IGStoryPeek only accesses and analyzes publicly available Instagram data. We do not access private profiles, direct messages, or any information that is not publicly visible. We are not affiliated with, endorsed by, or connected to Instagram or Meta Platforms, Inc.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">5. Cookies and Tracking</h2>
          <p>We use essential cookies for authentication and session management. We may use analytics cookies (Google Analytics) to understand usage patterns. We also use advertising cookies (Google AdSense) to serve relevant ads. You can control cookie preferences through your browser settings or by visiting our <a href={getLocalizedPath('/cookie-policy', lang)} class="text-primary hover:underline">Cookie Policy</a> page.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">6. Advertising</h2>
          <p>We use Google AdSense to display advertisements on our website. Google AdSense may use cookies and web beacons to collect data about your visits to this and other websites in order to provide targeted advertisements. Google's use of the DoubleClick cookie enables it and its partners to serve ads based on your browsing history.</p>
          <p class="mt-2">You may opt out of personalized advertising by visiting <a href="https://www.google.com/settings/ads" class="text-primary hover:underline" target="_blank" rel="noopener noreferrer">Google Ads Settings</a>. For more information, see our <a href={getLocalizedPath('/cookie-policy', lang)} class="text-primary hover:underline">Cookie Policy</a>.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">7. Third-Party Services</h2>
          <p>We use the following third-party services:</p>
          <ul class="list-disc list-inside space-y-1.5 ml-2 mt-2">
            <li>Firebase (Authentication, Database, Hosting)</li>
            <li>Google Analytics (Usage analytics)</li>
            <li>Google AdSense (Advertising)</li>
            <li>Stripe (Payment processing — for Pro subscribers)</li>
          </ul>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">8. Your Rights (GDPR/CCPA)</h2>
          <p>You have the right to access, correct, or delete your personal data. You may request a copy of your data or ask us to delete your account by contacting us at <a href="mailto:contact@igstorypeek.com" class="text-primary hover:underline">contact@igstorypeek.com</a>.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">9. Data Retention</h2>
          <p>We retain your account data for as long as your account is active. Search records are retained for 90 days unless you are a Pro subscriber, in which case they are retained for the duration of your subscription. You may request deletion at any time.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">10. Changes to This Policy</h2>
          <p>We may update this Privacy Policy from time to time. We will notify you of significant changes via email or a prominent notice on our website.</p>
        </div>

        <div>
          <h2 class="text-lg font-semibold text-white mb-3">11. Contact Us</h2>
          <p>If you have questions about this Privacy Policy, contact us at <a href="mailto:contact@igstorypeek.com" class="text-primary hover:underline">contact@igstorypeek.com</a>.</p>
        </div>
      </div>
    </div>
  </section>

  <FAQSection faqs={privacyFaqs} />
</MainLayout>

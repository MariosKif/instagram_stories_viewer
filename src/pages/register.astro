---
/**
 * Registration page — Firebase Email/Password + Google Auth.
 * Creates user profile in Firestore on successful signup.
 */
import MainLayout from '../layouts/MainLayout.astro';
import { getLocalizedPath } from '../i18n/utils';
import type { Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang || 'en';
const t = (Astro.locals as any).t || {};
---

<MainLayout title={t.register?.title || 'Create Account'} noIndex>
  <section class="min-h-screen flex items-center justify-center pt-20 pb-12 px-4">
    <div class="w-full max-w-md">
      <!-- Header -->
      <div class="text-center mb-8">
        <h1 class="text-3xl font-heading font-bold text-white mb-2">{t.register?.title || 'Create your account'}</h1>
        <p class="text-dark-400">{t.register?.subtitle || 'Start analyzing Instagram profiles for free.'}</p>
      </div>

      <!-- Card -->
      <div class="glass p-8">
        <!-- Google button -->
        <button
          id="google-btn"
          class="w-full flex items-center justify-center gap-3 px-4 py-3 bg-white hover:bg-gray-100 text-gray-800 font-medium rounded-xl transition-colors mb-6"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          {t.register?.googleSignUp || 'Continue with Google'}
        </button>

        <!-- Divider -->
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-white/10"></div>
          <span class="text-xs text-dark-500">{t.register?.orDivider || 'or'}</span>
          <div class="flex-1 h-px bg-white/10"></div>
        </div>

        <!-- Email form -->
        <form id="register-form" class="space-y-4" novalidate>
          <div>
            <label for="email" class="block text-sm font-medium text-dark-300 mb-1.5">{t.register?.emailLabel || 'Email'}</label>
            <input id="email" type="email" required class="input-field" placeholder={t.register?.emailPlaceholder || 'you@example.com'} />
          </div>
          <div>
            <label for="password" class="block text-sm font-medium text-dark-300 mb-1.5">{t.register?.passwordLabel || 'Password'}</label>
            <input id="password" type="password" required minlength="6" class="input-field" placeholder={t.register?.passwordPlaceholder || 'Min. 6 characters'} />
          </div>
          <div>
            <label for="confirm" class="block text-sm font-medium text-dark-300 mb-1.5">{t.register?.confirmPasswordLabel || 'Confirm Password'}</label>
            <input id="confirm" type="password" required class="input-field" placeholder={t.register?.confirmPasswordPlaceholder || 'Repeat password'} />
          </div>

          <p id="register-error" class="hidden text-red-400 text-sm"></p>

          <button type="submit" class="btn-primary w-full" id="submit-btn">
            {t.register?.submitButton || 'Create Account'}
          </button>
        </form>

        <!-- Terms -->
        <p class="text-center text-xs text-dark-500 mt-4">
          {t.register?.termsAgree || 'By signing up you agree to our'}
          <a href={getLocalizedPath('/terms', lang)} class="text-primary hover:underline">{t.register?.termsLink || 'Terms'}</a> {t.register?.andText || 'and'}
          <a href={getLocalizedPath('/privacy', lang)} class="text-primary hover:underline">{t.register?.privacyLink || 'Privacy Policy'}</a>.
        </p>

        <!-- Login link -->
        <p class="text-center text-sm text-dark-400 mt-6">
          {t.register?.hasAccount || 'Already have an account?'}
          <a href={getLocalizedPath('/login', lang)} class="text-primary hover:text-primary-300 font-medium">{t.register?.logIn || 'Log in'}</a>
        </p>
      </div>
    </div>
  </section>

  <script>
    import { register, loginWithGoogle } from '../lib/auth';
    import { ensureUserProfile } from '../lib/firestore';

    const form = document.getElementById('register-form') as HTMLFormElement;
    const googleBtn = document.getElementById('google-btn')!;
    const errorEl = document.getElementById('register-error')!;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.classList.remove('hidden');
    }

    function redirectAfterAuth() {
      const pending = localStorage.getItem('igsp_pending_search');
      if (pending) {
        localStorage.removeItem('igsp_pending_search');
        window.location.href = `/search/${encodeURIComponent(pending)}`;
      } else {
        window.location.href = '/dashboard';
      }
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorEl.classList.add('hidden');

      const email = (document.getElementById('email') as HTMLInputElement).value.trim();
      const password = (document.getElementById('password') as HTMLInputElement).value;
      const confirm = (document.getElementById('confirm') as HTMLInputElement).value;

      if (password !== confirm) {
        showError('Passwords do not match.');
        return;
      }
      if (password.length < 6) {
        showError('Password must be at least 6 characters.');
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = 'Creating account...';

      try {
        const user = await register(email, password);
        localStorage.setItem('igsp_uid', user.uid);
        localStorage.setItem('igsp_email', user.email || email);
        await ensureUserProfile(user.uid, user.email || email);
        redirectAfterAuth();
      } catch (err: any) {
        const code = err?.code || '';
        if (code === 'auth/email-already-in-use') {
          showError('An account with this email already exists.');
        } else if (code === 'auth/invalid-email') {
          showError('Please enter a valid email address.');
        } else if (code === 'auth/weak-password') {
          showError('Password is too weak. Use at least 6 characters.');
        } else {
          showError('Something went wrong. Please try again.');
        }
        submitBtn.disabled = false;
        submitBtn.textContent = 'Create Account';
      }
    });

    googleBtn.addEventListener('click', async () => {
      try {
        const user = await loginWithGoogle();
        localStorage.setItem('igsp_uid', user.uid);
        localStorage.setItem('igsp_email', user.email || '');
        await ensureUserProfile(user.uid, user.email || '');
        redirectAfterAuth();
      } catch (err: any) {
        if (err?.code !== 'auth/popup-closed-by-user') {
          showError('Google sign-in failed. Please try again.');
        }
      }
    });
  </script>
</MainLayout>

---
/**
 * Pricing page — Free vs Pro plans.
 * Stripe-ready structure with checkout placeholders.
 */
import MainLayout from '../layouts/MainLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import { getLocalizedPath, type Language } from '../i18n/utils';

const lang = (Astro.locals as any).lang as Language || 'en';
const t = (Astro.locals as any).t || {};
const pT = t.pricing || {};
const freeT = pT.free || {};
const proT = pT.pro || {};

const pricingFaqs = pT.faqs || [
  { question: 'Can I cancel anytime?', answer: 'Yes! You can cancel your Pro subscription at any time.' },
];
---

<MainLayout
  title={`${pT.title || 'Simple, Transparent'} ${pT.titleHighlight || 'Pricing'}`}
  description="Choose the right plan for your social media analytics needs. Start free or unlock unlimited access with Pro."
>
  <section class="pt-28 pb-20 lg:pt-36 lg:pb-28">
    <div class="section-container">
      <!-- Header -->
      <div class="text-center mb-16">
        <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">
          {pT.title || 'Simple, Transparent'} <span class="gradient-text">{pT.titleHighlight || 'Pricing'}</span>
        </h1>
        <p class="text-dark-400 text-lg max-w-xl mx-auto">
          {pT.subtitle || 'Start for free. Upgrade when you need more power.'}
        </p>
      </div>

      <!-- Cards -->
      <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
        <!-- Free plan -->
        <div class="glass p-8 flex flex-col">
          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white mb-1">{freeT.name || 'Free'}</h3>
            <p class="text-dark-400 text-sm">{freeT.description || 'For casual users and quick lookups.'}</p>
          </div>
          <div class="mb-8">
            <span class="text-4xl font-heading font-bold text-white">{freeT.price || '$0'}</span>
            <span class="text-dark-500 text-sm ml-1">{freeT.period || '/ month'}</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {freeT.feature1 || '2 searches every 8 hours'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {freeT.feature2 || 'Basic engagement report'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {freeT.feature3 || 'Profile overview'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-500">
              <svg class="w-5 h-5 text-dark-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              {freeT.excluded1 || 'No continuous monitoring'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-500">
              <svg class="w-5 h-5 text-dark-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" /></svg>
              {freeT.excluded2 || 'No AI insights'}
            </li>
          </ul>
          <a href={getLocalizedPath('/register', lang)} class="btn-secondary text-center">{freeT.cta || 'Get Started Free'}</a>
        </div>

        <!-- Pro plan -->
        <div class="glass p-8 flex flex-col border-primary/30 relative overflow-hidden">
          <div class="absolute top-4 right-4">
            <span class="badge text-xs">{proT.badge || 'Most Popular'}</span>
          </div>

          <div class="mb-6">
            <h3 class="text-lg font-semibold text-white mb-1">{proT.name || 'Pro'}</h3>
            <p class="text-dark-400 text-sm">{proT.description || 'For power users and professionals.'}</p>
          </div>
          <div class="mb-8">
            <span class="text-4xl font-heading font-bold text-white">{proT.price || '$29'}</span>
            <span class="text-dark-500 text-sm ml-1">{proT.period || '/ month'}</span>
          </div>
          <ul class="space-y-3 mb-8 flex-1">
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature1 || 'Unlimited searches'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature2 || 'Full analytics dashboard'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature3 || 'Continuous monitoring & alerts'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature4 || 'AI-powered insights'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature5 || 'Cross-platform detection'}
            </li>
            <li class="flex items-start gap-2.5 text-sm text-dark-300">
              <svg class="w-5 h-5 text-primary shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
              {proT.feature6 || 'Priority support'}
            </li>
          </ul>
          <button id="pro-checkout-btn" class="btn-primary text-center w-full">
            {proT.cta || 'Upgrade to Pro'}
          </button>
        </div>
      </div>

    </div>
  </section>

  <FAQSection faqs={pricingFaqs} />

  <script>
    document.getElementById('pro-checkout-btn')?.addEventListener('click', () => {
      const uid = localStorage.getItem('igsp_uid');
      if (!uid) {
        localStorage.setItem('igsp_pending_checkout', 'pro');
        window.location.href = '/login';
        return;
      }
      alert('Stripe checkout integration coming soon! This will redirect to a secure payment page.');
    });
  </script>
</MainLayout>

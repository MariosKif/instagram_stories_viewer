---
/**
 * Individual blog post page — full redesign with reading progress bar,
 * table of contents, share buttons, author card, and structured data.
 */
import MainLayout from '../../layouts/MainLayout.astro';
import { getCollection, getEntry } from 'astro:content';
import { getLocalizedPath } from '../../i18n/utils';
import type { Language } from '../../i18n/utils';

const lang = (Astro.locals as any).lang || 'en';
const t = (Astro.locals as any).t || {};

const { slug } = Astro.params;
if (!slug) return Astro.redirect(getLocalizedPath('/blog', lang), 302);

// Try localized post first, then fallback to English
const post = await getEntry('blog', `${lang}/${slug}`) || await getEntry('blog', `en/${slug}`);
if (!post) return Astro.redirect(getLocalizedPath('/blog', lang), 302);

const { Content, headings } = await post.render();

// Table of contents from H2 headings
const tocItems = headings.filter((h) => h.depth === 2);

// Reading time
function getReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}
const readingTime = getReadingTime(post.body ?? '');

// Parse FAQ pairs from the markdown body for FAQPage schema
function extractFaqs(body: string): { question: string; answer: string }[] {
  const faqs: { question: string; answer: string }[] = [];
  const faqHeadingMatch = body.match(/^## Frequently Asked Questions\s*$/m);
  if (!faqHeadingMatch || faqHeadingMatch.index === undefined) return faqs;

  const faqSection = body.slice(faqHeadingMatch.index + faqHeadingMatch[0].length);
  const h3Regex = /^### (.+)$/gm;
  let match: RegExpExecArray | null;
  const questions: { question: string; startIndex: number }[] = [];
  while ((match = h3Regex.exec(faqSection)) !== null) {
    questions.push({ question: match[1].trim(), startIndex: match.index + match[0].length });
  }
  for (let i = 0; i < questions.length; i++) {
    const end = i + 1 < questions.length ? faqSection.indexOf(`### ${questions[i + 1].question}`) : faqSection.length;
    const answer = faqSection.slice(questions[i].startIndex, end).trim();
    faqs.push({ question: questions[i].question, answer });
  }
  return faqs;
}

const blogFaqs = extractFaqs(post.body ?? '');
const faqSchema = blogFaqs.length > 0 ? JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: blogFaqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
}) : null;

// Related posts
function getPostSlug(p: any): string {
  return p.slug.includes('/') ? p.slug.split('/').slice(1).join('/') : p.slug;
}

const allPosts = await getCollection('blog');
let langPosts = allPosts.filter((p) => p.data.lang === lang);
if (langPosts.length === 0) langPosts = allPosts.filter((p) => p.data.lang === 'en');

const relatedPosts = langPosts
  .filter((p) => getPostSlug(p) !== slug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 2);

function formatDate(date: Date): string {
  return date.toLocaleDateString(lang === 'en' ? 'en-US' : lang, { month: 'long', day: 'numeric', year: 'numeric' });
}

function formatDateISO(date: Date): string {
  return date.toISOString();
}

const siteUrl = 'https://www.igstorypeek.com';
const postUrl = `${siteUrl}/blog/${slug}`;
const postImage = post.data.image ? `${siteUrl}${post.data.image}` : `${siteUrl}/blog/default-blog-hero.svg`;

// BlogPosting JSON-LD
const blogPostingSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  mainEntityOfPage: { '@type': 'WebPage', '@id': postUrl },
  headline: post.data.title,
  description: post.data.description,
  image: postImage,
  author: { '@type': 'Organization', name: post.data.author || 'IGStoryPeek', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'IGStoryPeek',
    url: siteUrl,
    logo: { '@type': 'ImageObject', url: `${siteUrl}/favicon.svg` },
  },
  datePublished: formatDateISO(post.data.pubDate),
  ...(post.data.updatedDate && { dateModified: formatDateISO(post.data.updatedDate) }),
  ...(post.data.tags && { keywords: post.data.tags.join(', ') }),
});

// BreadcrumbList JSON-LD
const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
});
---

<MainLayout
  title={post.data.title}
  description={post.data.description}
  ogImage={post.data.image}
>
  <!-- Reading Progress Bar -->
  <div id="reading-progress" class="fixed top-0 left-0 h-0.5 bg-gradient-to-r from-primary to-secondary z-50 transition-none" style="width: 0%"></div>

  <article class="pt-28 pb-20 lg:pt-36 lg:pb-28">
    <div class="section-container max-w-6xl">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-dark-500">
          <li><a href={getLocalizedPath('/', lang)} class="hover:text-primary transition-colors">Home</a></li>
          <li><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li><a href={getLocalizedPath('/blog', lang)} class="hover:text-primary transition-colors">Blog</a></li>
          <li><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-dark-300 truncate max-w-[140px] sm:max-w-[200px] md:max-w-none">{post.data.title}</li>
        </ol>
      </nav>

      <!-- Hero Image -->
      <div class="rounded-xl sm:rounded-2xl overflow-hidden mb-8">
        <img
          src={post.data.image || '/blog/default-blog-hero.svg'}
          alt={post.data.title}
          width="1200"
          height="630"
          decoding="async"
          class="w-full h-auto"
          fetchpriority="high"
        />
      </div>

      <!-- Header -->
      <header class="max-w-3xl mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-[11px] font-medium uppercase tracking-wider text-primary bg-primary/10 border border-primary/20 px-2.5 py-1 rounded-full">
            {post.data.category || 'Guides'}
          </span>
          <span class="text-xs text-dark-500">{readingTime} min read</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-heading font-bold text-white leading-tight mb-4">{post.data.title}</h1>
        <p class="text-lg text-dark-400 mb-4">{post.data.description}</p>
        <div class="flex flex-wrap items-center gap-4 text-sm text-dark-500">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            {post.data.author}
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            {formatDate(post.data.pubDate)}
          </div>
          {post.data.updatedDate && post.data.updatedDate.getTime() !== post.data.pubDate.getTime() && (
            <span class="text-dark-600">(Updated {formatDate(post.data.updatedDate)})</span>
          )}
        </div>
        {post.data.tags && post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {post.data.tags.map((tag: string) => (
              <span class="badge text-xs">{tag}</span>
            ))}
          </div>
        )}
      </header>
    </div>

    <!-- Content Area with TOC Sidebar -->
    <div class="section-container max-w-6xl">
      <div class="lg:grid lg:grid-cols-[1fr_240px] lg:gap-10">
        <!-- Main Content -->
        <div class="min-w-0">
          <div class="blog-content prose prose-invert max-w-none
            prose-headings:font-heading prose-headings:text-white prose-headings:scroll-mt-24
            prose-a:text-primary prose-a:no-underline hover:prose-a:underline
            prose-strong:text-white prose-strong:font-semibold
            prose-code:text-primary prose-code:bg-dark-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
            prose-pre:bg-dark-800 prose-pre:border prose-pre:border-dark-700
            prose-img:rounded-xl
            prose-th:bg-dark-800/50
            prose-td:text-dark-400
          ">
            <Content />
          </div>

          <!-- Share Buttons -->
          <div class="mt-12 pt-8 border-t border-white/5">
            <p class="text-sm font-medium text-dark-400 mb-4">Share this article</p>
            <div class="flex flex-wrap items-center gap-2 sm:gap-3">
              <a
                href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.data.title)}&url=${encodeURIComponent(postUrl)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-dark-800 border border-dark-700 text-sm text-dark-300 hover:text-white hover:border-dark-600 transition-colors"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                Share on X
              </a>
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(postUrl)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-dark-800 border border-dark-700 text-sm text-dark-300 hover:text-white hover:border-dark-600 transition-colors"
              >
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
              <button
                id="copy-link-btn"
                class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-dark-800 border border-dark-700 text-sm text-dark-300 hover:text-white hover:border-dark-600 transition-colors"
                data-url={postUrl}
              >
                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg>
                <span id="copy-link-text">Copy Link</span>
              </button>
            </div>
          </div>

          <!-- Author Card -->
          <div class="mt-10 glass p-6 flex items-start gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-primary to-secondary flex items-center justify-center flex-shrink-0">
              <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            </div>
            <div>
              <p class="font-heading font-semibold text-white">IGStoryPeek</p>
              <p class="text-sm text-dark-400 mt-1">Browse Instagram stories, highlights, reels, and posts from public accounts — no login required. Fast, free, and privacy-first.</p>
              <a href={getLocalizedPath('/', lang)} class="inline-block mt-2 text-sm text-primary hover:underline">Try IGStoryPeek &rarr;</a>
            </div>
          </div>
        </div>

        <!-- TOC Sidebar (desktop only) -->
        {tocItems.length > 2 && (
          <aside class="hidden lg:block">
            <nav class="sticky top-24" aria-label="Table of Contents">
              <p class="text-xs font-medium uppercase tracking-wider text-dark-500 mb-3">On this page</p>
              <ul class="space-y-2 text-sm border-l border-dark-700 pl-4">
                {tocItems.map((heading) => (
                  <li>
                    <a
                      href={`#${heading.slug}`}
                      class="toc-link block text-dark-500 hover:text-primary transition-colors leading-snug py-0.5"
                      data-slug={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          </aside>
        )}
      </div>
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <div class="section-container max-w-6xl mt-16 pt-10 border-t border-white/5">
        <h2 class="text-xl font-heading font-bold text-white mb-6">{t.blog?.relatedPosts || 'Related Posts'}</h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {relatedPosts.map((p) => (
            <a href={getLocalizedPath(`/blog/${getPostSlug(p)}`, lang)} class="glass overflow-hidden card-hover group block">
              <div class="h-40 overflow-hidden">
                <img
                  src={p.data.image || '/blog/default-blog-hero.svg'}
                  alt={p.data.title}
                  width="400"
                  height="160"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                />
              </div>
              <div class="p-5">
                <div class="flex items-center gap-3 mb-2">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-primary bg-primary/10 border border-primary/20 px-2 py-0.5 rounded-full">
                    {p.data.category || 'Guides'}
                  </span>
                  <span class="text-[11px] text-dark-500">{getReadingTime(p.body ?? '')} min read</span>
                </div>
                <h3 class="text-sm font-semibold text-white group-hover:text-primary transition-colors mb-1 line-clamp-2">{p.data.title}</h3>
                <p class="text-xs text-dark-500 line-clamp-2">{p.data.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}
  </article>

  {faqSchema && <script type="application/ld+json" set:html={faqSchema} />}
  <script type="application/ld+json" set:html={blogPostingSchema} />
  <script type="application/ld+json" set:html={breadcrumbSchema} />

  <script>
    // Reading progress bar
    function updateProgress() {
      const bar = document.getElementById('reading-progress');
      if (!bar) return;
      const docHeight = document.documentElement.scrollHeight - window.innerHeight;
      if (docHeight <= 0) return;
      const progress = Math.min((window.scrollY / docHeight) * 100, 100);
      bar.style.width = progress + '%';
    }
    window.addEventListener('scroll', updateProgress, { passive: true });
    updateProgress();

    // TOC active state
    const tocLinks = document.querySelectorAll('.toc-link');
    if (tocLinks.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              tocLinks.forEach((link) => link.classList.remove('text-primary', '!text-primary'));
              const active = document.querySelector(`.toc-link[data-slug="${entry.target.id}"]`);
              if (active) {
                active.classList.add('!text-primary');
              }
            }
          });
        },
        { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
      );
      document.querySelectorAll('h2[id]').forEach((h2) => observer.observe(h2));
    }

    // Copy link button
    const copyBtn = document.getElementById('copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', async () => {
        const url = copyBtn.getAttribute('data-url') || window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          const text = document.getElementById('copy-link-text');
          if (text) {
            text.textContent = 'Copied!';
            setTimeout(() => { text.textContent = 'Copy Link'; }, 2000);
          }
        } catch {}
      });
    }
  </script>
</MainLayout>

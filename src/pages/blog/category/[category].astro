---
/**
 * Blog category archive page — displays all posts for a given category.
 * SSR-rendered with BreadcrumbList JSON-LD.
 */
import MainLayout from '../../../layouts/MainLayout.astro';
import { getCollection } from 'astro:content';
import { getLocalizedPath } from '../../../i18n/utils';
import type { Language } from '../../../i18n/utils';

const lang = (Astro.locals as any).lang || 'en';
const { category } = Astro.params;
if (!category) return Astro.redirect(getLocalizedPath('/blog', lang), 302);

// Resolve display name from posts by matching the slug-ified category
const allPostsRaw = await getCollection('blog');
const enPosts = allPostsRaw.filter(p => p.data.lang === 'en');
const categoryMatch = enPosts.find(
  p => p.data.category && p.data.category.toLowerCase().replace(/\s+/g, '-') === category
);
if (!categoryMatch) return Astro.redirect(getLocalizedPath('/blog', lang), 302);
const categoryName = categoryMatch.data.category!;
const t = (Astro.locals as any).t || {};

const allPosts = await getCollection('blog');

function getPostSlug(post: any): string {
  return post.slug.includes('/') ? post.slug.split('/').slice(1).join('/') : post.slug;
}

function getPlatform(post: any): string {
  const slug = getPostSlug(post).toLowerCase();
  if (slug.startsWith('facebook-')) return 'facebook';
  if (slug.startsWith('tiktok-')) return 'tiktok';
  if (slug.startsWith('snapchat-')) return 'snapchat';
  return 'instagram';
}

function getPlatformImage(post: any): string {
  if (post.data.image && post.data.image !== '/blog/default-blog-hero.svg') {
    return post.data.image;
  }
  const platform = getPlatform(post);
  return `/blog/platform-${platform}.svg`;
}

function formatDate(date: Date): string {
  return date.toLocaleDateString(lang === 'en' ? 'en-US' : lang, { month: 'long', day: 'numeric', year: 'numeric' });
}

function getReadingTime(body: string): number {
  const words = body.trim().split(/\s+/).length;
  return Math.max(1, Math.ceil(words / 200));
}

const platformColors: Record<string, string> = {
  instagram: 'from-pink-500 to-orange-400',
  facebook: 'from-blue-600 to-blue-400',
  tiktok: 'from-cyan-400 to-pink-500',
  snapchat: 'from-yellow-400 to-yellow-300',
};

// Get posts for current language filtered by category, fallback to English
let langPosts = allPosts.filter((p) => p.data.lang === lang && p.data.category === categoryName);
if (langPosts.length === 0) langPosts = allPosts.filter((p) => p.data.lang === 'en' && p.data.category === categoryName);

const posts = langPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const siteUrl = 'https://www.igstorypeek.com';
const langPrefix = lang === 'en' ? '' : `/${lang}`;

const breadcrumbSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteUrl}${langPrefix || '/'}` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${siteUrl}${langPrefix}/blog` },
    { '@type': 'ListItem', position: 3, name: categoryName, item: `${siteUrl}${langPrefix}/blog/category/${categoryName.toLowerCase().replace(/\s+/g, '-')}` },
  ],
});
---

<MainLayout
  title={`${categoryName} — Blog — IGStoryPeek`}
  description={`Browse all ${categoryName} articles on IGStoryPeek. Tips, guides, and insights.`}
>
  <!-- Hero Section -->
  <section class="pt-28 pb-12 lg:pt-36 lg:pb-16 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-primary/5 via-transparent to-transparent pointer-events-none"></div>
    <div class="section-container max-w-6xl relative">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-8">
        <ol class="flex items-center gap-2 text-sm text-dark-500">
          <li><a href={getLocalizedPath('/', lang)} class="hover:text-primary transition-colors">Home</a></li>
          <li><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li><a href={getLocalizedPath('/blog', lang)} class="hover:text-primary transition-colors">Blog</a></li>
          <li><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg></li>
          <li class="text-dark-300">{categoryName}</li>
        </ol>
      </nav>

      <div class="max-w-2xl">
        <h1 class="text-4xl sm:text-5xl font-heading font-bold mb-4">
          <span class="gradient-text">{categoryName}</span>
        </h1>
        <p class="text-dark-400 text-lg">Browse all articles in the {categoryName} category.</p>
      </div>
    </div>
  </section>

  {posts.length > 0 ? (
    <section class="pb-20 lg:pb-28">
      <div class="section-container max-w-6xl">
        <!-- Posts Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4 sm:gap-6" id="posts-grid">
          {posts.map((post) => (
            <a href={getLocalizedPath(`/blog/${getPostSlug(post)}`, lang)} data-platform={getPlatform(post)} class="blog-card glass overflow-hidden card-hover group block">
              <div class="h-40 overflow-hidden relative">
                <img
                  src={getPlatformImage(post)}
                  alt={post.data.title}
                  width="400"
                  height="160"
                  decoding="async"
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                  loading="lazy"
                  onerror="this.src='/blog/default-blog-hero.svg'"
                />
                <span class={`absolute top-2 left-2 text-[9px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full text-white bg-gradient-to-r ${platformColors[getPlatform(post)]}`}>
                  {getPlatform(post)}
                </span>
              </div>
              <div class="p-4">
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-[10px] font-medium uppercase tracking-wider text-primary bg-primary/10 border border-primary/20 px-2 py-0.5 rounded-full">
                    {post.data.category || 'Guides'}
                  </span>
                  <span class="text-[11px] text-dark-500">{getReadingTime(post.body ?? '')} min read</span>
                </div>
                <h2 class="text-sm font-semibold text-white mb-1.5 group-hover:text-primary transition-colors line-clamp-2">
                  {post.data.title}
                </h2>
                <p class="text-xs text-dark-400 line-clamp-2">{post.data.description}</p>
                <div class="flex items-center gap-2 mt-2">
                  <time class="text-[10px] text-dark-500">{formatDate(post.data.pubDate)}</time>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  ) : (
    <section class="pb-20">
      <div class="section-container max-w-6xl">
        <div class="glass p-12 text-center">
          <p class="text-dark-500">No posts found in this category. <a href={getLocalizedPath('/blog', lang)} class="text-primary hover:underline">Back to Blog</a></p>
        </div>
      </div>
    </section>
  )}

  <script type="application/ld+json" set:html={breadcrumbSchema} />
</MainLayout>

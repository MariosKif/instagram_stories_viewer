---
/**
 * Main marketing layout — wraps public pages (homepage, pricing, blog, legal).
 * Includes Navbar, Footer, global styles, fonts, and SEO meta.
 */
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HreflangTags from '../components/HreflangTags.astro';
import { isRTL, type Language } from '../i18n/utils';
import Analytics from '../components/Analytics.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  canonical?: string;
  noIndex?: boolean;
}

const {
  title,
  description = 'Social media analytics and content tools. Analyze public profiles, track engagement trends, and discover insights across Instagram, TikTok, Facebook, and Snapchat.',
  ogImage = '/og-default.svg',
  ogType = 'website',
  canonical: canonicalOverride,
  noIndex = false,
} = Astro.props;

const lang = (Astro.locals as any).lang as Language || 'en';
const rtl = isRTL(lang);
const siteName = 'IGStoryPeek';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const siteBase = 'https://www.igstorypeek.com';
const siteUrl = siteBase;
const currentPath = Astro.url.pathname;
const canonical = canonicalOverride || `${siteBase}${currentPath}`;

// CJK/Arabic font families
const needsCJKFont = ['ja', 'ko', 'zh'].includes(lang);
const needsArabicFont = lang === 'ar';
---

<!doctype html>
<html lang={lang} dir={rtl ? 'rtl' : 'ltr'} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- SEO -->
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}
    <link rel="canonical" href={canonical} />

    <!-- Hreflang tags -->
    <HreflangTags lang={lang} path={currentPath} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Favicon & PWA -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#667eea" />

    <!-- Google Analytics -->
    <Analytics lang={lang} />

    <!-- DNS prefetch for third-party origins -->
    <link rel="dns-prefetch" href="https://pagead2.googlesyndication.com" />

    <!-- Self-hosted Latin fonts (Inter + Space Grotesk) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <!-- CJK/Arabic fonts from Google (too large to self-host) -->
    {needsCJKFont && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    )}
    {needsArabicFont && !needsCJKFont && (
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    )}
    {needsCJKFont && (
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700&family=Noto+Sans+KR:wght@400;500;600;700&family=Noto+Sans+SC:wght@400;500;600;700&display=swap"
        rel="stylesheet"
        media="print"
        onload="this.media='all'"
      />
    )}
    {needsArabicFont && (
      <link
        href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;500;600;700&display=swap"
        rel="stylesheet"
        media="print"
        onload="this.media='all'"
      />
    )}

    <!-- Google AdSense (deferred to idle time) -->
    <script>
      window.addEventListener('load', function() {
        var loadAds = function() {
          var s = document.createElement('script');
          s.src = 'https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-1279144350888956';
          s.crossOrigin = 'anonymous';
          s.async = true;
          document.head.appendChild(s);
        };
        if ('requestIdleCallback' in window) {
          requestIdleCallback(loadAds);
        } else {
          setTimeout(loadAds, 3000);
        }
      });
    </script>

    <!-- Extra head content (e.g. article OG tags from blog posts) -->
    <slot name="head" />

    <!-- Structured Data — SaaS / WebApplication schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "@id": `${siteBase}/#webapplication`,
      "name": siteName,
      "url": siteBase,
      "inLanguage": lang,
      "description": description,
      "applicationCategory": "SocialMediaApplication",
      "operatingSystem": "Web",
      "offers": {
        "@type": "AggregateOffer",
        "lowPrice": "0",
        "highPrice": "29.99",
        "priceCurrency": "USD",
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.8",
        "ratingCount": "1240",
      },
    })} />

    <!-- Organization schema -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "@id": `${siteBase}/#organization`,
      "name": siteName,
      "url": siteBase,
      "inLanguage": lang,
      "logo": {
        "@type": "ImageObject",
        "url": `${siteBase}/favicon.svg`,
        "width": 512,
        "height": 512,
      },
      "description": "Social media analytics and content tools for public profiles.",
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "contact@igstorypeek.com",
        "contactType": "customer support",
      },
    })} />

    {needsCJKFont && (
      <style>
        body { font-family: 'Inter', 'Noto Sans JP', 'Noto Sans KR', 'Noto Sans SC', sans-serif; }
      </style>
    )}
    {needsArabicFont && (
      <style>
        body { font-family: 'Inter', 'Noto Sans Arabic', sans-serif; }
      </style>
    )}
  </head>
  <body class="min-h-screen flex flex-col">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>

rules_version = '2';

// Firestore security rules for IGStoryPeek.
// Users can only read/write their own data.
service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection — each doc is keyed by Firebase Auth UID
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Searches collection — users can only access their own searches
    match /searches/{searchId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      // No update/delete — search records are immutable
    }

    // API cache — stores public Instagram data, not user-sensitive info
    match /apiCache/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Search result cache — full combined results with pre-computed reports
    match /searchCache/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
